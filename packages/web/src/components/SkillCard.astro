---
interface Props {
  skillJson: string;       // JSON-serialized Skill (server-rendered placeholder)
  versionJson: string;     // JSON-serialized SkillVersion
}
const { skillJson, versionJson } = Astro.props;
const skill = JSON.parse(skillJson);
const version = JSON.parse(versionJson);

const CATEGORY_COLORS: Record<string, string> = {
  safety: "#c33d3d",
  review: "#5b5bd6",
  debug: "#c67a00",
  write: "#00a47c",
  perf: "#7d4ec3",
  test: "#00879c",
  i18n: "#0072c6",
  git: "#5c6678",
};
const color = (skill.category && CATEGORY_COLORS[skill.category]) || "#5c6678";
const icon = skill.icon || "🧩";
const pain = version.pain || version.description || "";
const truncated = pain.length > 110 ? `${pain.slice(0, 110)}…` : pain;
---

<a class="skill-card" href={`/skills?slug=${encodeURIComponent(skill.slug)}`}>
  <div class="stripe" style={`background:${color}`}></div>
  <div class="body">
    <div class="head">
      <span class="icon">{icon}</span>
      <span class="name">{skill.name}</span>
    </div>
    <p class="pain">{truncated}</p>
    <div class="meta">
      <span class="ver">v{version.semver}</span>
      <span class="author">@{skill.authorId}</span>
    </div>
  </div>
</a>

<style>
  .skill-card {
    display: block; background: #fff; border: 1px solid #e6e8ee; border-radius: 10px;
    overflow: hidden; text-decoration: none; color: inherit;
    transition: transform 120ms, box-shadow 120ms;
  }
  .skill-card:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(20,20,40,.06); }
  .stripe { height: 4px; width: 100%; }
  .body { padding: 14px 16px 12px; }
  .head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .icon { font-size: 22px; }
  .name { font-weight: 600; }
  .pain { color: #5c6678; font-size: 13px; margin: 0 0 10px; min-height: 36px; }
  .meta { display: flex; justify-content: space-between; font-size: 12px; color: #8b91a0; }
  .ver { background: #eef0f5; padding: 1px 6px; border-radius: 4px; color: #5c6678; }
</style>
