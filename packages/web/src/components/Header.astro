---
// Server-rendered shell; the auth slot is filled by a tiny script that
// fetches /v1/me on the client. Phase 2 keeps this purely static —
// Phase 3 may move to cookie-aware SSR.
---
<header class="sharon-header">
  <a class="brand" href="/">
    <span class="brand-mark">🧩</span>
    <span class="brand-name">Matrix-Sharon</span>
    <span class="brand-sub">团队技能集市</span>
  </a>
  <div id="auth-slot" class="auth-slot" aria-live="polite">
    <span class="auth-loading">…</span>
  </div>
</header>

<style>
  .sharon-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    background: #fff;
    border-bottom: 1px solid #e6e8ee;
    font: 14px/1.4 -apple-system, "PingFang SC", sans-serif;
  }
  .brand { display: flex; align-items: baseline; gap: 8px; color: #1d2433; text-decoration: none; }
  .brand-mark { font-size: 20px; }
  .brand-name { font-weight: 600; }
  .brand-sub { color: #5c6678; font-size: 12px; }
  .auth-slot { min-height: 24px; display: flex; align-items: center; gap: 8px; }
  .auth-loading { color: #b2b7c0; }
  .auth-signin {
    background: #5b5bd6; color: #fff; padding: 6px 12px; border-radius: 6px;
    text-decoration: none; font-weight: 500;
  }
  .auth-signin:hover { background: #4747b3; }
  .auth-user { display: flex; align-items: center; gap: 8px; }
  .auth-avatar { width: 24px; height: 24px; border-radius: 50%; }
  .auth-name { color: #1d2433; }
  .auth-role {
    font-size: 11px; padding: 2px 6px; border-radius: 4px; background: #eef0f5; color: #5c6678;
  }
  .auth-role[data-role="leader"] { background: #fff4e0; color: #c67a00; }
  .auth-signout {
    background: transparent; border: 1px solid #d0d4dc; color: #5c6678;
    padding: 4px 10px; border-radius: 6px; cursor: pointer; font: inherit;
  }
  .auth-signout:hover { border-color: #b2b7c0; color: #1d2433; }
</style>

<script>
  type MeOk = {
    user: {
      id: string;
      githubId: number;
      name: string;
      email: string | null;
      avatarUrl: string | null;
      role: "leader" | "member";
    };
  };

  const slot = document.getElementById("auth-slot");
  if (slot) {
    fetch("/v1/me", { credentials: "same-origin" })
      .then(async (res) => {
        if (res.status === 401) return null;
        if (!res.ok) throw new Error(`/v1/me returned ${res.status}`);
        return (await res.json()) as MeOk;
      })
      .then((me) => {
        if (!me) {
          slot.innerHTML =
            '<a class="auth-signin" href="/login/github">使用 GitHub 登录</a>';
          return;
        }
        const u = me.user;
        const avatar = u.avatarUrl
          ? `<img class="auth-avatar" src="${u.avatarUrl}" alt="" />`
          : "";
        slot.innerHTML = `
          <div class="auth-user">
            ${avatar}
            <span class="auth-name">${escapeHtml(u.name)}</span>
            <span class="auth-role" data-role="${u.role}">${u.role}</span>
            <button class="auth-signout" type="button" id="auth-signout">登出</button>
          </div>
        `;
        document.getElementById("auth-signout")?.addEventListener("click", async () => {
          await fetch("/auth/logout", { method: "POST", credentials: "same-origin" });
          location.reload();
        });
      })
      .catch((err) => {
        console.error(err);
        slot.textContent = "登录状态加载失败";
      });
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }
</script>
