---
import Header from "../../components/Header.astro";
import "../../styles/tokens.css";
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>审批队列 · Matrix-Sharon</title>
    <style>
      .queue-toolbar {
        display: flex; align-items: center; justify-content: space-between;
        background: var(--warning-soft); border: 1px solid #ffe6c2;
        border-radius: var(--radius); padding: 14px 18px;
        margin-bottom: 20px; color: #8a5a00; font-size: 14px;
      }
      .pending-item { margin-bottom: 14px; }
      .pending-head { display: flex; gap: 16px; align-items: flex-start; justify-content: space-between; }
      .pending-head .col-info { flex: 1; min-width: 0; }
      .pending-head h3 { margin: 0 0 4px; font-size: 16px; display: flex; align-items: center; gap: 8px; }
      .pending-head .pending-meta { color: var(--fg-muted); font-size: 13px; margin: 0; line-height: 1.5; }
      .pending-actions { display: flex; gap: 8px; flex-shrink: 0; }
      .err { background: var(--danger-soft); color: var(--danger); border: 1px solid #f7caca; padding: 12px; border-radius: 6px; }
      .leader-only-empty { text-align: center; padding: 48px 24px; color: var(--fg-muted); }
    </style>
  </head>
  <body>
    <Header active="leader-queue" />
    <main class="container">
      <h1 class="h1">审批队列</h1>
      <p class="subtitle">leader 视角。通过 = 自动生成不可变版本 + 打包 <code>bundle.tgz</code>，立即对所有人可见可装。拒绝必填理由。</p>

      <div id="queue-toolbar-host"></div>
      <div id="queue" aria-live="polite">
        <p style="color:var(--fg-faint);">加载中…</p>
      </div>
    </main>

    <script>
      type Submission = {
        id: string; skillSlug: string; isNewSkill: boolean;
        bundleSha256: string; bundleSize: number; rawSkillMd: string;
        submitterId: string; submittedAt: number; status: string;
      };

      const queue = document.getElementById("queue")!;
      const toolbarHost = document.getElementById("queue-toolbar-host")!;

      function escapeHtml(s: string): string {
        return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
      }
      function fmt(ms: number): string {
        const days = Math.floor((Date.now() - ms) / 86400000);
        if (days === 0) {
          const h = Math.floor((Date.now() - ms) / 3600000);
          if (h === 0) return `${Math.floor((Date.now() - ms) / 60000)} 分钟前`;
          return `${h} 小时前`;
        }
        if (days === 1) return "昨天";
        return `${days} 天前`;
      }
      function showToast(msg: string) {
        const t = document.createElement("div"); t.className = "toast"; t.textContent = msg;
        document.body.appendChild(t); setTimeout(() => t.remove(), 2200);
      }

      async function load() {
        try {
          const res = await fetch("/v1/submissions/pending", { credentials: "same-origin" });
          if (res.status === 401) { location.href = `/login/github?returnTo=${encodeURIComponent("/leader/queue")}`; return; }
          if (res.status === 403) {
            queue.innerHTML = `<div class="leader-only-empty"><p>只有 leader 才能访问审批队列。</p><p><a href="/browse" class="btn">回到浏览</a></p></div>`;
            return;
          }
          if (!res.ok) throw new Error(`/v1/submissions/pending ${res.status}`);
          const body = (await res.json()) as { submissions: Submission[] };
          render(body.submissions);
        } catch (err) {
          console.error(err);
          queue.innerHTML = `<div class="err">加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      function render(items: Submission[]) {
        if (items.length === 0) {
          toolbarHost.innerHTML = "";
          queue.innerHTML = `<div class="empty-state"><span class="emoji">✓</span><p>队列已清空 · leader 的最高境界</p></div>`;
          return;
        }
        toolbarHost.innerHTML = `<div class="queue-toolbar">⏳ 待审 <b>${items.length}</b> 个提交。等你 review。</div>`;
        queue.innerHTML = items.map((s) => `
          <div class="card pending-item" data-id="${s.id}">
            <div class="pending-head">
              <div class="col-info">
                <h3>
                  ${escapeHtml(s.skillSlug)}
                  <span class="tag ${s.isNewSkill ? 'green' : 'amber'}">${s.isNewSkill ? '首发' : '新版本'}</span>
                </h3>
                <p class="pending-meta">提交人 @${escapeHtml(s.submitterId)} · ${fmt(s.submittedAt)} · bundle <code>${s.bundleSha256.slice(0, 12)}…</code> (${(s.bundleSize / 1024).toFixed(1)} KB)</p>
              </div>
              <div class="pending-actions">
                <button class="btn success" data-act="approve">通过</button>
                <button class="btn danger" data-act="reject">拒绝</button>
              </div>
            </div>
            <div class="diff-box">${escapeHtml(s.rawSkillMd)}</div>
          </div>
        `).join("");

        queue.querySelectorAll<HTMLButtonElement>(".btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const card = btn.closest<HTMLDivElement>(".pending-item")!;
            const id = card.dataset["id"]!;
            const act = btn.dataset["act"];
            if (act === "approve") {
              const note = (window.prompt("可选 note（直接回车跳过）") ?? "").trim();
              btn.disabled = true;
              try {
                const r = await fetch(`/v1/submissions/${encodeURIComponent(id)}/approve`, {
                  method: "POST", credentials: "same-origin",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(note ? { note } : {}),
                });
                if (!r.ok) throw new Error(`approve ${r.status}: ${await r.text()}`);
                showToast("✓ 已通过，版本已生成");
                card.remove();
                const remaining = queue.querySelectorAll(".pending-item").length;
                if (remaining === 0) render([]);
                else toolbarHost.innerHTML = `<div class="queue-toolbar">⏳ 待审 <b>${remaining}</b> 个提交。</div>`;
              } catch (err) { btn.disabled = false; alert(`通过失败：${err}`); }
            } else if (act === "reject") {
              const reason = window.prompt("拒绝理由（必填）：");
              if (!reason || reason.trim().length === 0) { alert("理由不能为空"); return; }
              btn.disabled = true;
              try {
                const r = await fetch(`/v1/submissions/${encodeURIComponent(id)}/reject`, {
                  method: "POST", credentials: "same-origin",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ reason }),
                });
                if (!r.ok) throw new Error(`reject ${r.status}: ${await r.text()}`);
                showToast("已拒绝");
                card.remove();
                const remaining = queue.querySelectorAll(".pending-item").length;
                if (remaining === 0) render([]);
                else toolbarHost.innerHTML = `<div class="queue-toolbar">⏳ 待审 <b>${remaining}</b> 个提交。</div>`;
              } catch (err) { btn.disabled = false; alert(`拒绝失败：${err}`); }
            }
          });
        });
      }

      load();
    </script>
  </body>
</html>
