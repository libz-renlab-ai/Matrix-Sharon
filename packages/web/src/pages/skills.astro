---
import Header from "../components/Header.astro";
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Skill 详情 · Matrix-Sharon</title>
    <style>
      body { margin: 0; font-family: -apple-system, "PingFang SC", sans-serif; background: #f7f8fb; color: #1d2433; }
      main { padding: 32px 24px; max-width: 1080px; margin: 0 auto; }
      .skel { background: #fff; border: 1px solid #e6e8ee; border-radius: 8px; padding: 24px; color: #b2b7c0; }
      .err { background: #fff3f3; color: #c33d3d; border: 1px solid #f7caca; padding: 16px; border-radius: 8px; }
      .back { color: #5b5bd6; text-decoration: none; font-size: 14px; }
      .back:hover { text-decoration: underline; }

      .hero { background: #fff; border: 1px solid #e6e8ee; border-radius: 10px; padding: 20px 24px; margin-bottom: 16px; }
      .hero h1 { display: flex; align-items: center; gap: 10px; margin: 0 0 6px; font-size: 22px; }
      .hero .icon { font-size: 28px; }
      .hero .meta { display: flex; gap: 12px; align-items: center; font-size: 13px; color: #5c6678; }
      .cat-pill { padding: 2px 8px; border-radius: 4px; color: #fff; font-size: 11px; }
      .ver-pill { background: #eef0f5; padding: 2px 8px; border-radius: 4px; color: #5c6678; font-size: 12px; }

      .grid { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; }
      @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }

      .readme {
        background: #fff; border: 1px solid #e6e8ee; border-radius: 10px;
        padding: 24px; line-height: 1.7;
      }
      .readme h1, .readme h2, .readme h3 { margin-top: 1.4em; margin-bottom: 0.4em; }
      .readme code { background: #eef0f5; padding: 1px 5px; border-radius: 4px; font-size: 0.92em; }
      .readme pre {
        background: #2b303b; color: #f5f7fa; padding: 12px; border-radius: 6px;
        overflow-x: auto; font-size: 13px;
      }
      .readme pre code { background: transparent; color: inherit; padding: 0; }

      .side { display: flex; flex-direction: column; gap: 12px; }
      .four-block { background: #fff; border: 1px solid #e6e8ee; border-radius: 10px; padding: 16px; }
      .four-block h3 { margin: 0 0 6px; font-size: 13px; color: #8b91a0; text-transform: uppercase; letter-spacing: 0.04em; }
      .four-block p { margin: 0; font-size: 14px; color: #1d2433; }

      .versions {
        background: #fff; border: 1px solid #e6e8ee; border-radius: 10px;
        padding: 16px 20px; margin-top: 16px;
      }
      .versions h2 { margin: 0 0 12px; font-size: 16px; }
      .versions table { width: 100%; border-collapse: collapse; font-size: 13px; }
      .versions th, .versions td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #f0f2f5; }
      .versions th { color: #5c6678; font-weight: 500; font-size: 12px; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <p><a class="back" href="/browse">← 返回浏览</a></p>
      <div id="detail-root">
        <div class="skel">加载中…</div>
      </div>
    </main>

    <script>
      type Skill = { slug: string; name: string; category: string | null; icon: string | null; authorId: string };
      type SkillVersion = {
        id: string; semver: number; description: string; pain: string | null; gain: string | null;
        triggers: string | null; exampleJson: string | null; publishedAt: number; approvedAt: number;
        publishedBy: string; approvedBy: string;
      };
      type DetailResponse = { skill: Skill; versions: SkillVersion[]; currentVersionId: string | null };
      type ReadmeResponse = { html: string; semver: number };

      const CATEGORY_COLORS: Record<string, string> = {
        safety: "#c33d3d", review: "#5b5bd6", debug: "#c67a00", write: "#00a47c",
        perf: "#7d4ec3", test: "#00879c", i18n: "#0072c6", git: "#5c6678",
      };

      const slug = new URLSearchParams(location.search).get("slug");
      const root = document.getElementById("detail-root")!;

      function escapeHtml(s: string): string {
        return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
      }
      function fmtDate(ms: number): string { return new Date(ms).toISOString().slice(0, 10); }

      async function load() {
        if (!slug) {
          root.innerHTML = '<div class="err">缺少 slug 参数。</div>';
          return;
        }
        try {
          const res = await fetch(`/v1/skills/${encodeURIComponent(slug)}`, { credentials: "same-origin" });
          if (res.status === 401) {
            location.href = `/login/github?returnTo=${encodeURIComponent(location.pathname + location.search)}`;
            return;
          }
          if (res.status === 404) {
            root.innerHTML = '<div class="err">未找到该 skill。<a href="/browse">回到浏览</a></div>';
            return;
          }
          if (!res.ok) throw new Error(`detail ${res.status}`);
          const detail = (await res.json()) as DetailResponse;
          renderShell(detail);
          wireInstallButton();
          wirePushButton();
          await loadReadme(detail);
        } catch (err) {
          console.error(err);
          root.innerHTML = `<div class="err">加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      function renderShell(d: DetailResponse) {
        const current = d.versions.find((v) => v.id === d.currentVersionId) ?? d.versions[0];
        if (!current) {
          root.innerHTML = '<div class="err">该 skill 还没有任何版本。</div>';
          return;
        }
        const color = (d.skill.category && CATEGORY_COLORS[d.skill.category]) || "#5c6678";
        const icon = d.skill.icon || "🧩";
        root.innerHTML = `
          <div class="hero">
            <h1>
              <span class="icon">${icon}</span>
              <span>${escapeHtml(d.skill.name)}</span>
            </h1>
            <div class="meta">
              ${d.skill.category ? `<span class="cat-pill" style="background:${color}">${escapeHtml(d.skill.category)}</span>` : ""}
              <span class="ver-pill">v${current.semver}（当前）</span>
              <span>by @${escapeHtml(d.skill.authorId)}</span>
              <button id="install-btn" data-slug="${escapeHtml(d.skill.slug)}" data-semver="${current.semver}"
                style="margin-left:auto;background:#5b5bd6;color:#fff;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font:inherit;">
                ⬇ 一键安装
              </button>
              <button id="push-btn" data-slug="${escapeHtml(d.skill.slug)}" data-semver="${current.semver}"
                style="display:none;background:#c67a00;color:#fff;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font:inherit;">
                📤 推送给成员
              </button>
            </div>
          </div>
          <div class="grid">
            <div id="readme-pane" class="readme">加载 readme…</div>
            <div class="side">
              ${current.pain ? `<div class="four-block"><h3>解决的问题</h3><p>${escapeHtml(current.pain)}</p></div>` : ""}
              ${current.gain ? `<div class="four-block"><h3>装上后</h3><p>${escapeHtml(current.gain)}</p></div>` : ""}
              ${current.triggers ? `<div class="four-block"><h3>触发条件</h3><p>${escapeHtml(current.triggers)}</p></div>` : ""}
            </div>
          </div>
          <div class="versions">
            <h2>所有版本</h2>
            <table>
              <thead><tr><th>版本</th><th>发布时间</th><th>提交人</th><th>审批人</th></tr></thead>
              <tbody>
                ${d.versions.map((v) => `
                  <tr>
                    <td>v${v.semver}${v.id === d.currentVersionId ? " · 当前" : ""}</td>
                    <td>${fmtDate(v.publishedAt)}</td>
                    <td>@${escapeHtml(v.publishedBy)}</td>
                    <td>@${escapeHtml(v.approvedBy)}</td>
                  </tr>
                `).join("")}
              </tbody>
            </table>
          </div>
        `;
      }

      type IntentResponse = { token: string; deepLink: string; fallbackCmd: string };

      type MeResponse = {
        user: {
          id: string;
          githubId: number;
          name: string;
          email: string | null;
          avatarUrl: string | null;
          role: "leader" | "member";
        };
      };
      type UserLite = {
        id: string;
        name: string;
        role: "leader" | "member";
        avatarUrl: string | null;
      };

      function wireInstallButton() {
        const btn = document.getElementById("install-btn") as HTMLButtonElement | null;
        if (!btn) return;
        btn.addEventListener("click", async () => {
          btn.disabled = true;
          btn.textContent = "请求中…";
          try {
            const res = await fetch("/v1/install-intent", {
              method: "POST",
              credentials: "same-origin",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                skillSlug: btn.dataset["slug"],
                semver: Number(btn.dataset["semver"]),
              }),
            });
            if (res.status === 401) {
              location.href = `/login/github?returnTo=${encodeURIComponent(location.pathname + location.search)}`;
              return;
            }
            if (!res.ok) throw new Error(`intent ${res.status}`);
            const intent = (await res.json()) as IntentResponse;
            showInstallModal(intent);
          } catch (err) {
            console.error(err);
            alert(`安装请求失败：${err}`);
            btn.disabled = false;
            btn.textContent = "⬇ 一键安装";
          }
        });
      }

      function showInstallModal(intent: IntentResponse) {
        // Try the deep link; if no handler registered, browser does nothing.
        const tryStart = Date.now();
        let triedDeepLink = false;
        const tryDeepLink = () => {
          triedDeepLink = true;
          location.href = intent.deepLink;
        };

        const modal = document.createElement("div");
        modal.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:1000;";
        modal.innerHTML = `
          <div style="background:#fff;border-radius:10px;padding:24px;max-width:520px;width:90%;font-family:inherit;">
            <h2 style="margin:0 0 12px;font-size:18px;">一键安装</h2>
            <p id="install-status" style="color:#5c6678;margin:0 0 12px;font-size:14px;">尝试唤起本地 sharon CLI…</p>
            <div id="install-fallback" style="display:none;">
              <p style="font-size:13px;color:#5c6678;margin:0 0 8px;">
                浏览器无法唤起 sharon。把下面的命令贴到终端跑（先 export SHARON_TOKEN=…）：
              </p>
              <div style="background:#f0f1f5;border-radius:6px;padding:10px 12px;font-family:ui-monospace,Menlo,monospace;font-size:13px;display:flex;align-items:center;gap:8px;">
                <code id="install-cmd" style="flex:1;">${escapeHtml(intent.fallbackCmd)}</code>
                <button id="install-copy" style="background:#5b5bd6;color:#fff;border:none;padding:4px 10px;border-radius:4px;cursor:pointer;font-size:12px;">复制</button>
              </div>
            </div>
            <div style="text-align:right;margin-top:16px;">
              <button id="install-close" style="background:transparent;border:1px solid #d0d4dc;color:#5c6678;padding:6px 14px;border-radius:6px;cursor:pointer;font:inherit;">关闭</button>
            </div>
          </div>
        `;
        document.body.appendChild(modal);
        document.getElementById("install-close")!.addEventListener("click", () => modal.remove());
        document.getElementById("install-copy")!.addEventListener("click", async () => {
          await navigator.clipboard.writeText(intent.fallbackCmd);
          (document.getElementById("install-copy") as HTMLButtonElement).textContent = "已复制";
        });
        tryDeepLink();
        setTimeout(() => {
          if (triedDeepLink && Date.now() - tryStart >= 1500) {
            const s = document.getElementById("install-status");
            if (s) s.textContent = "sharon CLI 没有响应（或本机未注册 sharon:// scheme）。";
            const fb = document.getElementById("install-fallback");
            if (fb) fb.style.display = "block";
          }
        }, 1800);
      }

      async function wirePushButton() {
        const btn = document.getElementById("push-btn") as HTMLButtonElement | null;
        if (!btn) return;
        // Show the button only if the current user is a leader.
        let me: MeResponse | null = null;
        try {
          const res = await fetch("/v1/me", { credentials: "same-origin" });
          if (res.status === 401) return;
          if (!res.ok) return;
          me = (await res.json()) as MeResponse;
        } catch (err) {
          console.error(err);
          return;
        }
        if (!me || me.user.role !== "leader") return;
        btn.style.display = "";
        const leaderId = me.user.id;
        btn.addEventListener("click", () => {
          showPushModal({
            skillSlug: String(btn.dataset["slug"]),
            semver: Number(btn.dataset["semver"]),
            leaderId,
          });
        });
      }

      function showPushModal(opts: { skillSlug: string; semver: number; leaderId: string }) {
        const modal = document.createElement("div");
        modal.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:1000;";
        modal.innerHTML = `
          <div style="background:#fff;border-radius:10px;padding:24px;max-width:560px;width:90%;font-family:inherit;max-height:90vh;display:flex;flex-direction:column;">
            <h2 style="margin:0 0 12px;font-size:18px;">推送给成员</h2>
            <p style="color:#5c6678;margin:0 0 14px;font-size:13px;">
              选择要推送给的成员，写一句推送理由，提交后他们会在「我的推送」里看到。
            </p>
            <div id="push-pickers" style="overflow-y:auto;border:1px solid #e6e8ee;border-radius:6px;padding:8px 12px;margin-bottom:12px;max-height:240px;">
              <p style="color:#b2b7c0;margin:0;font-size:13px;">加载成员列表…</p>
            </div>
            <label style="display:block;margin-bottom:6px;font-size:13px;color:#5c6678;">推送理由（必填）</label>
            <textarea id="push-reason" rows="3" placeholder="例如：team-debug-helper 升级到 v2，请大家更新"
              style="width:100%;box-sizing:border-box;font:inherit;padding:8px 10px;border:1px solid #d0d4dc;border-radius:6px;resize:vertical;"></textarea>
            <div style="text-align:right;margin-top:16px;display:flex;gap:8px;justify-content:flex-end;">
              <button id="push-cancel" style="background:transparent;border:1px solid #d0d4dc;color:#5c6678;padding:6px 14px;border-radius:6px;cursor:pointer;font:inherit;">取消</button>
              <button id="push-submit" style="background:#c67a00;color:#fff;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;font:inherit;">确认推送</button>
            </div>
          </div>
        `;
        document.body.appendChild(modal);
        const close = () => modal.remove();
        document.getElementById("push-cancel")!.addEventListener("click", close);

        const pickers = document.getElementById("push-pickers")!;
        const submitBtn = document.getElementById("push-submit") as HTMLButtonElement;
        const reasonEl = document.getElementById("push-reason") as HTMLTextAreaElement;

        // Load member list
        (async () => {
          try {
            const res = await fetch("/v1/users", { credentials: "same-origin" });
            if (!res.ok) throw new Error(`/v1/users ${res.status}`);
            const body = (await res.json()) as { users: UserLite[] };
            const members = body.users.filter((u) => u.role === "member" && u.id !== opts.leaderId);
            if (members.length === 0) {
              pickers.innerHTML = `<p style="color:#5c6678;margin:0;font-size:13px;">没有可推送的成员。</p>`;
              return;
            }
            pickers.innerHTML = members.map((u) => `
              <label style="display:flex;align-items:center;gap:8px;padding:6px 0;cursor:pointer;font-size:14px;">
                <input type="checkbox" class="push-recipient" value="${escapeHtml(u.id)}" />
                <span>${escapeHtml(u.name)}</span>
                <span style="color:#8b91a0;font-size:12px;">@${escapeHtml(u.id)}</span>
              </label>
            `).join("");
          } catch (err) {
            console.error(err);
            pickers.innerHTML = `<p class="err" style="margin:0;">加载成员失败：${escapeHtml(String(err))}</p>`;
          }
        })();

        submitBtn.addEventListener("click", async () => {
          const reason = reasonEl.value.trim();
          if (reason.length === 0) {
            alert("推送理由不能为空");
            return;
          }
          const recipientIds = Array.from(
            pickers.querySelectorAll<HTMLInputElement>("input.push-recipient:checked")
          ).map((cb) => cb.value);
          if (recipientIds.length === 0) {
            alert("请至少选一个成员");
            return;
          }
          submitBtn.disabled = true;
          submitBtn.textContent = "推送中…";
          try {
            const r = await fetch("/v1/pushes", {
              method: "POST",
              credentials: "same-origin",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                skillSlug: opts.skillSlug,
                semver: opts.semver,
                recipientIds,
                reason,
              }),
            });
            if (!r.ok) throw new Error(`push ${r.status}: ${await r.text()}`);
            alert(`已推送给 ${recipientIds.length} 位成员。`);
            close();
          } catch (err) {
            console.error(err);
            submitBtn.disabled = false;
            submitBtn.textContent = "确认推送";
            alert(`推送失败：${err}`);
          }
        });
      }

      async function loadReadme(d: DetailResponse) {
        const current = d.versions.find((v) => v.id === d.currentVersionId) ?? d.versions[0];
        if (!current) return;
        const pane = document.getElementById("readme-pane");
        if (!pane) return;
        try {
          const res = await fetch(
            `/v1/skills/${encodeURIComponent(d.skill.slug)}/versions/${current.semver}/readme`,
            { credentials: "same-origin" }
          );
          if (!res.ok) throw new Error(`readme ${res.status}`);
          const r = (await res.json()) as ReadmeResponse;
          pane.innerHTML = r.html;
        } catch (err) {
          console.error(err);
          pane.innerHTML = `<div class="err">readme 加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      load();
    </script>
  </body>
</html>
