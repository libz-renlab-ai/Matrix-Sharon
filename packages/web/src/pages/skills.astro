---
import Header from "../components/Header.astro";
import "../styles/tokens.css";
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Skill 详情 · Matrix-Sharon</title>
    <style>
      .crumb { color: var(--fg-faint); font-size: 13px; margin-bottom: 12px; }
      .crumb a { color: var(--primary); }

      .detail-head { margin-bottom: 20px; }
      .detail-head h1 {
        font-size: 30px; margin: 0 0 6px; letter-spacing: -0.4px;
        display: flex; align-items: center; gap: 12px;
      }
      .detail-head h1 .skill-icon { width: 42px; height: 42px; font-size: 22px; }
      .detail-head p.desc { color: var(--fg-muted); margin: 0 0 14px; font-size: 15px; }
      .meta-row {
        display: flex; flex-wrap: wrap; gap: 14px;
        align-items: center;
        color: var(--fg-muted); font-size: 13px;
      }
      .meta-row .dot { color: var(--border-strong); }
      .mini-avatar { width: 18px; height: 18px; border-radius: 50%; vertical-align: middle; margin-right: 4px; }

      .detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 28px; }
      @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }

      /* value-prop card */
      .value-prop-detail {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 22px 26px;
        margin-bottom: 20px;
      }
      .value-prop-detail h3 { font-size: 14px; color: var(--fg-muted); margin: 0 0 14px; font-weight: 600; }
      .vpd-row { display: flex; gap: 14px; padding: 10px 0; border-top: 1px solid var(--border); align-items: flex-start; }
      .vpd-row:first-of-type { border-top: none; padding-top: 0; }
      .vpd-icon { width: 34px; height: 34px; border-radius: 8px; display: grid; place-items: center; font-size: 17px; flex-shrink: 0; }
      .vpd-row.pain .vpd-icon { background: var(--danger-soft); }
      .vpd-row.gain .vpd-icon { background: var(--accent-soft); }
      .vpd-row.trig .vpd-icon { background: var(--warning-soft); }
      .vpd-row.example .vpd-icon { background: var(--primary-soft); }
      .vpd-body { flex: 1; min-width: 0; }
      .vpd-title { font-size: 13px; font-weight: 600; color: var(--fg-muted); margin-bottom: 2px; }
      .vpd-text { color: var(--fg); font-size: 14px; line-height: 1.55; }

      /* readme */
      .readme {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px 32px;
      }
      .readme h1, .readme h2, .readme h3 { color: var(--fg); margin-top: 24px; margin-bottom: 12px; }
      .readme h1 { font-size: 22px; } .readme h2 { font-size: 18px; } .readme h3 { font-size: 15px; }
      .readme p { margin: 12px 0; }
      .readme ul, .readme ol { margin: 12px 0; padding-left: 22px; }
      .readme li { margin: 4px 0; }
      .readme pre {
        background: var(--surface-2); padding: 14px 16px;
        border-radius: var(--radius-sm); overflow-x: auto;
        border: 1px solid var(--border); max-height: 280px;
      }
      .readme code:not(pre code) {
        background: var(--surface-2); padding: 2px 6px;
        border-radius: 4px; color: #b34a4a; font-size: 0.88em;
      }
      .readme hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }

      /* sidebar */
      .side { display: flex; flex-direction: column; gap: 16px; }
      .side-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 18px 20px;
      }
      .side-card h3 {
        font-size: 13px; color: var(--fg-muted); margin: 0 0 12px;
        font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
      }
      .install-cmd {
        font-family: var(--mono); font-size: 12px; color: var(--fg-muted);
        background: var(--surface-2); padding: 8px 10px; border-radius: 6px;
        margin-top: 10px; overflow-x: auto; white-space: nowrap;
      }
      .install-hint { font-size: 11px; color: var(--fg-faint); margin-top: 6px; }

      /* vote */
      .vote-block { display: flex; align-items: center; gap: 14px; }
      .vote-btn {
        width: 64px; height: 64px;
        border: 2px solid var(--border-strong);
        border-radius: 10px; background: var(--surface);
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 2px; cursor: pointer;
        transition: border-color 0.12s, background 0.12s, color 0.12s;
      }
      .vote-btn:hover { border-color: var(--primary); color: var(--primary); }
      .vote-btn.voted { border-color: var(--primary); background: var(--primary-soft); color: var(--primary); }
      .vote-btn .arrow { font-size: 18px; font-weight: 700; }
      .vote-btn .count { font-weight: 700; font-size: 14px; }
      .vote-info { font-size: 12px; color: var(--fg-muted); line-height: 1.5; }

      /* versions list */
      .versions-list { list-style: none; padding: 0; margin: 0; }
      .versions-list li { padding: 8px 0; border-top: 1px solid var(--border); font-size: 13px; display: flex; gap: 8px; align-items: baseline; }
      .versions-list li:first-child { border-top: none; padding-top: 0; }
      .versions-list .v { color: var(--primary); font-family: var(--mono); font-weight: 600; }
      .versions-list .when { color: var(--fg-faint); font-size: 12px; margin-left: auto; }

      /* push dialog kind selector */
      .kind-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
      .kind-pill {
        padding: 6px 12px; border-radius: 999px; border: 1px solid var(--border-strong);
        background: var(--surface); color: var(--fg-muted);
        font-size: 12px; font-weight: 500; cursor: pointer;
        display: inline-flex; align-items: center; gap: 4px;
      }
      .kind-pill.active { border-color: var(--primary); background: var(--primary-soft); color: var(--primary); }
      .kind-pill.future { opacity: 0.5; cursor: not-allowed; }
      .kind-pill .eta { font-size: 10px; padding: 1px 5px; border-radius: 3px; background: var(--surface-2); color: var(--fg-faint); }

      .member-pick-list { max-height: 240px; overflow-y: auto; border: 1px solid var(--border); border-radius: 6px; padding: 8px 12px; margin-bottom: 12px; }
      .member-row { display: flex; align-items: center; gap: 8px; padding: 6px 0; font-size: 14px; cursor: pointer; }
      .member-row + .member-row { border-top: 1px solid var(--border); }
      .member-row .role-badge { font-size: 10px; }

      textarea.reason {
        width: 100%; box-sizing: border-box; font: inherit;
        padding: 8px 10px; border: 1px solid var(--border-strong); border-radius: 6px; resize: vertical;
      }

      .err { background: var(--danger-soft); color: var(--danger); border: 1px solid #f7caca; padding: 16px; border-radius: 8px; }
      .skel { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 24px; color: var(--fg-faint); }
    </style>
  </head>
  <body>
    <Header active="browse" />
    <main class="container">
      <div id="detail-root">
        <div class="skel">加载中…</div>
      </div>
    </main>

    <script>
      type Skill = { slug: string; name: string; category: string | null; icon: string | null; authorId: string };
      type SkillVersion = {
        id: string; semver: number; description: string; pain: string | null; gain: string | null;
        triggers: string | null; exampleJson: string | null; publishedAt: number; approvedAt: number;
        publishedBy: string; approvedBy: string;
      };
      type DetailResponse = { skill: Skill; versions: SkillVersion[]; currentVersionId: string | null };
      type ReadmeResponse = { html: string; semver: number };
      type MeResponse = { user: { id: string; role: "leader" | "member" } };
      type UserLite = { id: string; name: string; role: "leader" | "member"; avatarUrl: string | null };

      const KNOWN_CATS = new Set(["safety","review","debug","write","perf","test","i18n","git"]);
      const slug = new URLSearchParams(location.search).get("slug");
      const root = document.getElementById("detail-root")!;

      function escapeHtml(s: string): string {
        return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
      }
      function fmtDate(ms: number): string {
        const days = Math.floor((Date.now() - ms) / 86400000);
        if (days === 0) return "今天";
        if (days === 1) return "昨天";
        if (days < 30) return `${days} 天前`;
        return new Date(ms).toISOString().slice(0, 10);
      }

      async function load() {
        if (!slug) { root.innerHTML = '<div class="err">缺少 slug 参数。</div>'; return; }
        try {
          const res = await fetch(`/v1/skills/${encodeURIComponent(slug)}`, { credentials: "same-origin" });
          if (res.status === 401) {
            location.href = `/login/github?returnTo=${encodeURIComponent(location.pathname + location.search)}`;
            return;
          }
          if (res.status === 404) {
            root.innerHTML = '<div class="err">未找到该 skill。<a href="/browse">回到浏览</a></div>';
            return;
          }
          if (!res.ok) throw new Error(`detail ${res.status}`);
          const detail = (await res.json()) as DetailResponse;
          renderShell(detail);
          wireInstallButton();
          await wirePushButton();
          await loadReadme(detail);
        } catch (err) {
          console.error(err);
          root.innerHTML = `<div class="err">加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      function renderShell(d: DetailResponse) {
        const current = d.versions.find((v) => v.id === d.currentVersionId) ?? d.versions[0];
        if (!current) {
          root.innerHTML = '<div class="err">该 skill 还没有任何版本。</div>';
          return;
        }
        const cat = d.skill.category && KNOWN_CATS.has(d.skill.category) ? d.skill.category : "review";
        const icon = d.skill.icon || "🧩";

        const vpdRows: string[] = [];
        if (current.pain) {
          vpdRows.push(`
            <div class="vpd-row pain">
              <div class="vpd-icon">❓</div>
              <div class="vpd-body"><div class="vpd-title">解决什么问题</div><div class="vpd-text">${escapeHtml(current.pain)}</div></div>
            </div>`);
        }
        if (current.gain) {
          vpdRows.push(`
            <div class="vpd-row gain">
              <div class="vpd-icon">✨</div>
              <div class="vpd-body"><div class="vpd-title">装上后会发生什么</div><div class="vpd-text">${escapeHtml(current.gain)}</div></div>
            </div>`);
        }
        if (current.triggers) {
          vpdRows.push(`
            <div class="vpd-row trig">
              <div class="vpd-icon">⚡</div>
              <div class="vpd-body"><div class="vpd-title">什么时候触发</div><div class="vpd-text">${escapeHtml(current.triggers)}</div></div>
            </div>`);
        }
        if (current.exampleJson) {
          try {
            const ex = JSON.parse(current.exampleJson) as { user?: string; sharon?: string };
            if (ex.user || ex.sharon) {
              vpdRows.push(`
                <div class="vpd-row example">
                  <div class="vpd-icon">🔎</div>
                  <div class="vpd-body">
                    <div class="vpd-title">来个例子</div>
                    <div class="vpd-text" style="font-family:var(--mono);font-size:13px;">
                      ${ex.user ? `<div><b>你：</b>${escapeHtml(ex.user)}</div>` : ""}
                      ${ex.sharon ? `<div style="margin-top:4px;color:var(--accent);"><b>Sharon：</b>${escapeHtml(ex.sharon)}</div>` : ""}
                    </div>
                  </div>
                </div>`);
            }
          } catch { /* ignore malformed example_json */ }
        }

        root.innerHTML = `
          <div class="crumb"><a href="/browse">← 全部 skill</a> / ${escapeHtml(d.skill.name)}</div>

          <div class="detail-head">
            <h1><span class="skill-icon cat-${cat}">${icon}</span><span>${escapeHtml(d.skill.name)}</span></h1>
            <p class="desc">${escapeHtml(current.description || current.gain || "")}</p>
            <div class="meta-row">
              <span><img class="mini-avatar" src="https://github.com/${encodeURIComponent(d.skill.authorId)}.png" onerror="this.style.display='none'"/> @${escapeHtml(d.skill.authorId)}</span>
              <span class="dot">·</span>
              <span class="tag green">v${current.semver}（当前）</span>
              <span class="dot">·</span>
              <span>${fmtDate(current.publishedAt)}发布</span>
              ${d.skill.category ? `<span class="dot">·</span><span class="tag">${escapeHtml(d.skill.category)}</span>` : ""}
            </div>
          </div>

          <div class="detail-grid">
            <div>
              ${vpdRows.length > 0 ? `
                <div class="value-prop-detail">
                  <h3>💡 好处一目了然</h3>
                  ${vpdRows.join("")}
                </div>` : ""}
              <div id="readme-pane" class="readme">加载 readme…</div>
            </div>

            <div class="side">
              <div class="side-card">
                <h3>安装</h3>
                <button class="btn primary big block" id="install-btn" data-slug="${escapeHtml(d.skill.slug)}" data-semver="${current.semver}">⬇ 一键安装到本地</button>
                <div class="install-cmd">$ sharon install ${escapeHtml(d.skill.slug)}@${current.semver}</div>
                <div class="install-hint">📦 解压到 ~/.claude/skills/${escapeHtml(d.skill.slug)}/</div>
                <button class="btn warning block" id="push-btn" data-slug="${escapeHtml(d.skill.slug)}" data-semver="${current.semver}" style="display:none;margin-top:10px;">📤 推送给成员</button>
              </div>

              <div class="side-card">
                <h3>投票 · 团队信号</h3>
                <div class="vote-block">
                  <button class="vote-btn" id="vote-btn" disabled title="投票功能即将上线（v1.x）">
                    <span class="arrow">▲</span>
                    <span class="count">—</span>
                  </button>
                  <div class="vote-info">
                    给真的好用的 skill 投票，<br/>让团队信号浮上来。
                    <div style="color:var(--fg-faint);font-size:11px;margin-top:4px;">投票功能 v1.x 加</div>
                  </div>
                </div>
              </div>

              <div class="side-card">
                <h3>所有版本</h3>
                <ul class="versions-list">
                  ${d.versions.map((v) => `
                    <li>
                      <span class="v">v${v.semver}</span>
                      ${v.id === d.currentVersionId ? '<span class="tag green">当前</span>' : ""}
                      <span class="when">${fmtDate(v.publishedAt)}</span>
                    </li>
                  `).join("")}
                </ul>
              </div>

              <div class="side-card">
                <h3>作者</h3>
                <div style="display:flex;align-items:center;gap:10px;">
                  <img class="mini-avatar" style="width:32px;height:32px;" src="https://github.com/${encodeURIComponent(d.skill.authorId)}.png" onerror="this.style.display='none'"/>
                  <div>
                    <div style="font-weight:600;">@${escapeHtml(d.skill.authorId)}</div>
                    <div style="font-size:12px;color:var(--fg-muted);">原作者 · 审批 @${escapeHtml(current.approvedBy)}</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        `;
      }

      function wireInstallButton() {
        const btn = document.getElementById("install-btn") as HTMLButtonElement | null;
        if (!btn) return;
        btn.addEventListener("click", async () => {
          btn.disabled = true;
          const origText = btn.textContent;
          btn.textContent = "请求中…";
          try {
            const res = await fetch("/v1/install-intent", {
              method: "POST", credentials: "same-origin",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ skillSlug: btn.dataset["slug"], semver: Number(btn.dataset["semver"]) }),
            });
            if (res.status === 401) {
              location.href = `/login/github?returnTo=${encodeURIComponent(location.pathname + location.search)}`;
              return;
            }
            if (!res.ok) throw new Error(`intent ${res.status}`);
            const intent = (await res.json()) as { token: string; deepLink: string; fallbackCmd: string };
            showInstallModal(intent);
          } catch (err) {
            console.error(err);
            alert(`安装请求失败：${err}`);
            btn.disabled = false; btn.textContent = origText;
          }
        });
      }

      function showInstallModal(intent: { deepLink: string; fallbackCmd: string }) {
        const tryStart = Date.now();
        let triedDeepLink = false;
        const tryDeepLink = () => { triedDeepLink = true; location.href = intent.deepLink; };

        const bg = document.createElement("div");
        bg.className = "dialog-bg show";
        bg.innerHTML = `
          <div class="dialog">
            <h3>一键安装</h3>
            <p id="install-status">尝试唤起本地 sharon CLI…</p>
            <div id="install-fallback" style="display:none;">
              <p style="font-size:13px;">浏览器无法唤起 sharon。把下面的命令贴到终端跑（先 <code>export SHARON_TOKEN=…</code>）：</p>
              <div style="background:var(--surface-2);border-radius:6px;padding:10px 12px;font-family:var(--mono);font-size:13px;display:flex;align-items:center;gap:8px;">
                <code id="install-cmd" style="flex:1;">${escapeHtml(intent.fallbackCmd)}</code>
                <button class="btn small" id="install-copy">复制</button>
              </div>
            </div>
            <div class="dialog-actions">
              <button class="btn" id="install-close">关闭</button>
            </div>
          </div>
        `;
        document.body.appendChild(bg);
        document.getElementById("install-close")!.addEventListener("click", () => bg.remove());
        document.getElementById("install-copy")!.addEventListener("click", async () => {
          await navigator.clipboard.writeText(intent.fallbackCmd);
          (document.getElementById("install-copy") as HTMLButtonElement).textContent = "已复制";
        });
        tryDeepLink();
        setTimeout(() => {
          if (triedDeepLink && Date.now() - tryStart >= 1500) {
            const s = document.getElementById("install-status");
            if (s) s.textContent = "sharon CLI 没有响应（或本机未注册 sharon:// scheme）。";
            const fb = document.getElementById("install-fallback");
            if (fb) fb.style.display = "block";
          }
        }, 1800);
      }

      async function wirePushButton() {
        const btn = document.getElementById("push-btn") as HTMLButtonElement | null;
        if (!btn) return;
        let me: MeResponse | null = null;
        try {
          const res = await fetch("/v1/me", { credentials: "same-origin" });
          if (!res.ok) return;
          me = (await res.json()) as MeResponse;
        } catch { return; }
        if (!me || me.user.role !== "leader") return;
        btn.style.display = "";
        const leaderId = me.user.id;
        btn.addEventListener("click", () => {
          showPushModal({ skillSlug: String(btn.dataset["slug"]), semver: Number(btn.dataset["semver"]), leaderId });
        });
      }

      function showPushModal(opts: { skillSlug: string; semver: number; leaderId: string }) {
        const bg = document.createElement("div");
        bg.className = "dialog-bg show";
        bg.innerHTML = `
          <div class="dialog wide">
            <h3>📤 推送到成员</h3>
            <p>将该资源以"必装"的形式推送给指定成员。他们运行 <code>sharon receive</code> 时会自动安装。</p>

            <div style="margin-bottom:14px;">
              <div style="font-size:12px;color:var(--fg-muted);margin-bottom:6px;font-weight:600;">推送类型</div>
              <div class="kind-row">
                <span class="kind-pill active">🧩 Skill</span>
                <span class="kind-pill future">📐 Viki 规则 <span class="eta">v1.1+</span></span>
                <span class="kind-pill future">🔀 Workflow <span class="eta">v1.1+</span></span>
                <span class="kind-pill future">💬 Prompt 模板 <span class="eta">v1.1+</span></span>
              </div>
            </div>

            <div style="font-size:12px;color:var(--fg-muted);margin-bottom:6px;font-weight:600;">选择成员</div>
            <div id="push-pickers" class="member-pick-list">
              <p style="color:var(--fg-faint);margin:0;font-size:13px;">加载成员列表…</p>
            </div>

            <label style="display:block;margin-bottom:6px;font-size:12px;color:var(--fg-muted);font-weight:600;">推送理由（必填）</label>
            <textarea class="reason" id="push-reason" rows="3" placeholder="例如：team-debug-helper 升级到 v2，请大家更新"></textarea>

            <div class="dialog-actions">
              <button class="btn" id="push-cancel">取消</button>
              <button class="btn warning" id="push-submit">确认推送 <span id="push-count"></span></button>
            </div>
          </div>
        `;
        document.body.appendChild(bg);
        const close = () => bg.remove();
        document.getElementById("push-cancel")!.addEventListener("click", close);

        const pickers = document.getElementById("push-pickers")!;
        const submitBtn = document.getElementById("push-submit") as HTMLButtonElement;
        const countEl = document.getElementById("push-count")!;
        const reasonEl = document.getElementById("push-reason") as HTMLTextAreaElement;

        function refreshCount() {
          const n = pickers.querySelectorAll<HTMLInputElement>("input.push-recipient:checked").length;
          countEl.textContent = n > 0 ? `（${n} 人）` : "";
          submitBtn.disabled = n === 0;
        }
        submitBtn.disabled = true;

        (async () => {
          try {
            const res = await fetch("/v1/users", { credentials: "same-origin" });
            if (!res.ok) throw new Error(`/v1/users ${res.status}`);
            const body = (await res.json()) as { users: UserLite[] };
            const others = body.users.filter((u) => u.id !== opts.leaderId);
            if (others.length === 0) {
              pickers.innerHTML = `<p style="color:var(--fg-muted);margin:0;font-size:13px;">没有可推送的成员。让团队其他人先登录一次。</p>`;
              return;
            }
            pickers.innerHTML = others.map((u) => `
              <label class="member-row">
                <input type="checkbox" class="push-recipient" value="${escapeHtml(u.id)}" />
                <img class="mini-avatar" src="${u.avatarUrl || `https://github.com/${encodeURIComponent(u.id)}.png`}" onerror="this.style.display='none'"/>
                <span>${escapeHtml(u.name)}</span>
                <span class="role-badge ${u.role}">${u.role}</span>
                <span style="color:var(--fg-faint);font-size:12px;margin-left:auto;">@${escapeHtml(u.id)}</span>
              </label>
            `).join("");
            pickers.querySelectorAll<HTMLInputElement>("input.push-recipient").forEach((cb) => {
              cb.addEventListener("change", refreshCount);
            });
          } catch (err) {
            console.error(err);
            pickers.innerHTML = `<p style="color:var(--danger);margin:0;font-size:13px;">加载成员失败：${escapeHtml(String(err))}</p>`;
          }
        })();

        submitBtn.addEventListener("click", async () => {
          const reason = reasonEl.value.trim();
          if (reason.length === 0) { alert("推送理由不能为空"); return; }
          const recipientIds = Array.from(pickers.querySelectorAll<HTMLInputElement>("input.push-recipient:checked")).map((cb) => cb.value);
          if (recipientIds.length === 0) return;
          submitBtn.disabled = true; submitBtn.textContent = "推送中…";
          try {
            const r = await fetch("/v1/pushes", {
              method: "POST", credentials: "same-origin",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ skillSlug: opts.skillSlug, semver: opts.semver, recipientIds, reason }),
            });
            if (!r.ok) throw new Error(`push ${r.status}: ${await r.text()}`);
            showToast(`已推送给 ${recipientIds.length} 位成员。`);
            close();
          } catch (err) {
            console.error(err);
            submitBtn.disabled = false; submitBtn.textContent = "确认推送";
            alert(`推送失败：${err}`);
          }
        });
      }

      function showToast(msg: string) {
        const t = document.createElement("div");
        t.className = "toast";
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 2200);
      }

      async function loadReadme(d: DetailResponse) {
        const current = d.versions.find((v) => v.id === d.currentVersionId) ?? d.versions[0];
        if (!current) return;
        const pane = document.getElementById("readme-pane");
        if (!pane) return;
        try {
          const res = await fetch(`/v1/skills/${encodeURIComponent(d.skill.slug)}/versions/${current.semver}/readme`,
            { credentials: "same-origin" });
          if (!res.ok) throw new Error(`readme ${res.status}`);
          const r = (await res.json()) as ReadmeResponse;
          pane.innerHTML = r.html;
        } catch (err) {
          console.error(err);
          pane.innerHTML = `<div class="err">readme 加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      load();
    </script>
  </body>
</html>
