---
import Header from "../../components/Header.astro";
import "../../styles/tokens.css";
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>待我决定 · Matrix-Sharon</title>
    <style>
      .candidate-card { margin-bottom: 14px; }
      .candidate-head { display: flex; gap: 16px; align-items: flex-start; justify-content: space-between; }
      .candidate-head .col-info { flex: 1; min-width: 0; }
      .candidate-head h3 { margin: 0 0 4px; font-size: 16px; font-weight: 600; }
      .candidate-head .reason { color: var(--fg-muted); font-size: 13px; margin: 0; line-height: 1.5; }
      .candidate-head .time { color: var(--fg-faint); font-size: 12px; margin: 6px 0 0; }
      .candidate-actions { display: flex; gap: 8px; flex-shrink: 0; }
      .err { background: var(--danger-soft); color: var(--danger); border: 1px solid #f7caca; padding: 12px; border-radius: 6px; }
    </style>
  </head>
  <body>
    <Header active="me" />
    <main class="container">
      <h1 class="h1">待我决定</h1>
      <p class="subtitle">本地 scanner（<code>sharon scan</code>）发现的候选 skill。选「发布候选」会进入 leader 审批队列；「忽略」会让该候选不再出现。</p>
      <div id="list" aria-live="polite">
        <p style="color:var(--fg-faint);">加载中…</p>
      </div>
    </main>

    <script>
      type Candidate = {
        id: string;
        userId: string;
        skillSlug: string;
        detectedAt: number;
        reason: string;
        diffUnified: string | null;
        fullContentMd: string;
      };

      const list = document.getElementById("list")!;

      function escapeHtml(s: string): string {
        return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
      }
      function fmt(ms: number): string {
        const d = new Date(ms);
        return `${d.toISOString().slice(0, 10)} ${d.toISOString().slice(11, 16)}`;
      }
      function renderDiff(diff: string): string {
        return diff.split("\n").map((line) => {
          let cls = "ctx";
          if (line.startsWith("@@"))      cls = "hunk";
          else if (line.startsWith("+"))  cls = "add";
          else if (line.startsWith("-"))  cls = "del";
          return `<div class="diff-line ${cls}">${escapeHtml(line || " ")}</div>`;
        }).join("");
      }

      async function load() {
        try {
          const res = await fetch("/v1/candidates/mine", { credentials: "same-origin" });
          if (res.status === 401) {
            location.href = `/login/github?returnTo=${encodeURIComponent("/me/candidates")}`;
            return;
          }
          if (!res.ok) throw new Error(`/v1/candidates/mine ${res.status}`);
          const body = (await res.json()) as { candidates: Candidate[] };
          render(body.candidates);
        } catch (err) {
          console.error(err);
          list.innerHTML = `<div class="err">加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      function render(items: Candidate[]) {
        if (items.length === 0) {
          list.innerHTML = `
            <div class="empty-state">
              <span class="emoji">✓</span>
              <p>当前没有待决定的候选 skill。</p>
              <p style="font-size:13px;color:var(--fg-faint);">跑 <code>sharon scan</code> 扫描本地 <code>~/.claude/skills/</code>，或直接用 <code>sharon publish</code> 提交。</p>
            </div>`;
          return;
        }
        list.innerHTML = items.map((c) => {
          const preview = c.diffUnified
            ? `<div class="diff-box">${renderDiff(c.diffUnified)}</div>`
            : `<div class="diff-box">${escapeHtml(c.fullContentMd)}</div>`;
          return `
            <div class="card candidate-card" data-id="${c.id}">
              <div class="candidate-head">
                <div class="col-info">
                  <h3>${escapeHtml(c.skillSlug)}</h3>
                  <p class="reason">${escapeHtml(c.reason)}</p>
                  <p class="time">${fmt(c.detectedAt)}</p>
                </div>
                <div class="candidate-actions">
                  <button class="btn primary" data-act="submit">发布候选 →</button>
                  <button class="btn ghost" data-act="dismiss">忽略</button>
                </div>
              </div>
              ${preview}
            </div>`;
        }).join("");

        list.querySelectorAll<HTMLButtonElement>(".btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const row = btn.closest<HTMLDivElement>(".candidate-card");
            if (!row) return;
            const id = row.dataset["id"]!;
            const act = btn.dataset["act"];
            btn.disabled = true;
            try {
              if (act === "submit") {
                const r = await fetch("/v1/submissions", {
                  method: "POST", credentials: "same-origin",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({ candidateId: id }),
                });
                if (!r.ok) throw new Error(`submit ${r.status}: ${await r.text()}`);
                showToast("已提交到 leader 审批队列");
              } else if (act === "dismiss") {
                const r = await fetch(`/v1/candidates/${encodeURIComponent(id)}`, {
                  method: "DELETE", credentials: "same-origin",
                });
                if (!r.ok) throw new Error(`dismiss ${r.status}`);
                showToast("已忽略");
              }
              row.remove();
              if (list.children.length === 0) render([]);
            } catch (err) {
              console.error(err);
              btn.disabled = false;
              alert(`操作失败：${err}`);
            }
          });
        });
      }

      function showToast(msg: string) {
        const t = document.createElement("div");
        t.className = "toast";
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 2200);
      }

      load();
    </script>
  </body>
</html>
