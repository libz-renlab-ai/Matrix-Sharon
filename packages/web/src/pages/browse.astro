---
import Header from "../components/Header.astro";
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>浏览 · Matrix-Sharon</title>
    <style>
      body { margin: 0; font-family: -apple-system, "PingFang SC", sans-serif; background: #f7f8fb; color: #1d2433; }
      main { padding: 32px 24px; max-width: 1080px; margin: 0 auto; }
      h1 { margin: 0 0 24px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
      .skeleton { background: #fff; border: 1px solid #e6e8ee; border-radius: 10px; height: 132px; }
      .err { background: #fff3f3; color: #c33d3d; border: 1px solid #f7caca; padding: 16px; border-radius: 8px; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>浏览技能</h1>
      <div id="browse-grid" class="grid" aria-live="polite">
        <div class="skeleton"></div>
        <div class="skeleton"></div>
        <div class="skeleton"></div>
      </div>
    </main>

    <script>
      type SkillsResponse = {
        skills: Array<{
          skill: { slug: string; name: string; category: string | null; icon: string | null; authorId: string };
          currentVersion: { semver: number; description: string; pain: string | null };
        }>;
      };

      const CATEGORY_COLORS: Record<string, string> = {
        safety: "#c33d3d", review: "#5b5bd6", debug: "#c67a00", write: "#00a47c",
        perf: "#7d4ec3", test: "#00879c", i18n: "#0072c6", git: "#5c6678",
      };

      const grid = document.getElementById("browse-grid")!;

      async function load() {
        try {
          const res = await fetch("/v1/skills", { credentials: "same-origin" });
          if (res.status === 401) {
            location.href = `/login/github?returnTo=${encodeURIComponent("/browse")}`;
            return;
          }
          if (!res.ok) throw new Error(`/v1/skills returned ${res.status}`);
          const body = (await res.json()) as SkillsResponse;
          if (body.skills.length === 0) {
            grid.outerHTML = `
              <div class="empty" style="text-align:center;padding:64px 24px;color:#5c6678;">
                <div style="font-size:48px;margin-bottom:12px">🧩</div>
                <h2 style="margin:0 0 6px;color:#1d2433">还没有 skill</h2>
                <p style="margin:0;font-size:14px">
                  跑 <code>pnpm --filter @matrix-sharon/server exec sharon-server-seed</code> 灌入 3 个样例。
                </p>
              </div>
            `;
            return;
          }
          grid.innerHTML = body.skills.map((row) => renderCard(row)).join("");
        } catch (err) {
          console.error(err);
          grid.innerHTML = `<div class="err">加载失败：${escapeHtml(String(err))}</div>`;
        }
      }

      function renderCard(row: SkillsResponse["skills"][number]): string {
        const color = (row.skill.category && CATEGORY_COLORS[row.skill.category]) || "#5c6678";
        const icon = row.skill.icon || "🧩";
        const pain = row.currentVersion.pain || row.currentVersion.description || "";
        const trunc = pain.length > 110 ? pain.slice(0, 110) + "…" : pain;
        const href = `/skills?slug=${encodeURIComponent(row.skill.slug)}`;
        return `
          <a class="skill-card" href="${href}" style="display:block;background:#fff;border:1px solid #e6e8ee;border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;">
            <div style="height:4px;background:${color}"></div>
            <div style="padding:14px 16px 12px;">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                <span style="font-size:22px">${icon}</span>
                <span style="font-weight:600">${escapeHtml(row.skill.name)}</span>
              </div>
              <p style="color:#5c6678;font-size:13px;margin:0 0 10px;min-height:36px;">${escapeHtml(trunc)}</p>
              <div style="display:flex;justify-content:space-between;font-size:12px;color:#8b91a0;">
                <span style="background:#eef0f5;padding:1px 6px;border-radius:4px;color:#5c6678">v${row.currentVersion.semver}</span>
                <span>@${escapeHtml(row.skill.authorId)}</span>
              </div>
            </div>
          </a>
        `;
      }

      function escapeHtml(s: string): string {
        return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
      }

      load();
    </script>
  </body>
</html>
