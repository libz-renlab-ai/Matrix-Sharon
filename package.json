{
  "name": "matrix-sharon",
  "version": "0.0.0",
  "private": true,
  "description": "团队技能集市 — Claude Code skills 共享平台",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev": "concurrently --names server,web --prefix-colors blue,magenta --kill-others-on-fail \"pnpm --filter @matrix-sharon/server dev\" \"pnpm --filter @matrix-sharon/web dev\"",
    "seed": "node packages/server/bin/sharon-server-seed.mjs",
    "sharon": "node packages/cli/bin/sharon.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3"
  }
}
