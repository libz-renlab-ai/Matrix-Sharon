# Matrix-Sharon — environment template
# Copy to .env at the repo root (or packages/server/.env). Both are loaded
# by the server. Never commit .env to git.

# ── Required for production ─────────────────────────────────────────────────
# Signing secret for the sharon_session cookie. Generate once and keep stable
# — rotating invalidates everyone's sessions.
#   openssl rand -hex 32
SHARON_SESSION_SECRET=

# ── GitHub OAuth (required for real login) ──────────────────────────────────
# Register an OAuth app at https://github.com/settings/developers
#   Homepage URL:            http://127.0.0.1:4321
#   Authorization callback:  http://127.0.0.1:4321/auth/callback
# Without these the server still boots, but /login/github returns 503.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────
# Bind host / port. Default 127.0.0.1:4321.
HOST=127.0.0.1
PORT=4321

# Public-facing base URL used when building OAuth callback URLs. Default
# derived from HOST:PORT. Override when running behind a reverse proxy.
# SHARON_PUBLIC_BASE_URL=https://sharon.example.com

# Where the SQLite database + bundles live. Default ./data
# SHARON_DATA_DIR=/var/lib/sharon

# CLI: where to reach the server, and the session cookie (paste from browser
# DevTools → Application → Cookies → sharon_session).
# SHARON_BASE_URL=http://127.0.0.1:4321
# SHARON_TOKEN=
